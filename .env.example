# WeiLinkBot Environment Variables
# Copy this file to .env and fill in your values

# LLM Provider Configuration
WEILINKBOT_LLM__API_KEY=sk-your-api-key-here
WEILINKBOT_LLM__BASE_URL=https://api.openai.com/v1
WEILINKBOT_LLM__MODEL=gpt-4o-mini

# Bot Configuration
WEILINKBOT_BOT__BASE_URL=https://ilinkai.weixin.qq.com

# Server
WEILINKBOT_SERVER__HOST=0.0.0.0
WEILINKBOT_SERVER__PORT=8000
